---
interface Props {
  slug: string;
  title: string;
  date: string;
  category: string;
  tldr: string;
  confidence: 'high' | 'medium';
}
const { slug, title, date, category, tldr, confidence } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<article class="bg-yoju-bg-card border border-yoju-border rounded-xl p-6 hover:shadow-md transition-shadow">
  <a href={`/${slug}`} class="block group">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-sm font-semibold text-yoju-orange bg-amber-50 px-3 py-1 rounded-full">
        {category}
      </span>
      <span class="text-sm text-yoju-text-muted">{formattedDate}</span>
      {confidence === 'high'
        ? <span class="text-sm text-green-700 bg-green-50 px-2 py-0.5 rounded-full">✅ 高可信</span>
        : <span class="text-sm text-yellow-700 bg-yellow-50 px-2 py-0.5 rounded-full">⚠️ 中可信</span>
      }
    </div>

    <h2 class="text-xl font-bold text-yoju-text group-hover:text-yoju-orange transition-colors mb-3 leading-snug">
      {title}
    </h2>

    <p class="text-base text-yoju-text-muted leading-relaxed line-clamp-3">
      {tldr}
    </p>

    <p class="mt-3 text-base text-yoju-orange font-semibold">閱讀全文 →</p>
  </a>
</article>
