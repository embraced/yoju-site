---
interface Props {
  tldr: string;
  confidence: 'high' | 'medium';
}
const { tldr, confidence } = Astro.props;
---

<div class="bg-amber-50 border-l-4 border-yoju-orange rounded-r-lg px-6 py-5 my-6">
  <p class="text-sm font-semibold text-yoju-orange mb-2 uppercase tracking-wide">重點摘要 TL;DR</p>
  <p class="text-lg text-yoju-text leading-relaxed">{tldr}</p>
  <p class="mt-3 text-sm text-yoju-text-muted">
    🤖 AI 生成・已查證來源・
    {confidence === 'high' ? '✅ 高可信度' : '⚠️ 中可信度'} ·
    <strong>僅供參考，請諮詢醫師</strong>
  </p>
</div>
