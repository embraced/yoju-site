---
interface Props {
  articleUrl?: string;
}

const { articleUrl } = Astro.props;

const FORM_SHORT_URL = 'https://forms.gle/F2gho2rvhnbbysdk7';
const FORM_PREFILL_BASE =
  'https://docs.google.com/forms/d/e/1FAIpQLSc7HeqE-xBBxbwvIvsopySz61dHCREAJJvuPvONpK39UdV6uQ/viewform';
const FORM_ARTICLE_ENTRY = 'entry.1554535540';

const feedbackUrl = articleUrl
  ? `${FORM_PREFILL_BASE}?usp=pp_url&${FORM_ARTICLE_ENTRY}=${encodeURIComponent(articleUrl)}`
  : FORM_SHORT_URL;

const FEEDBACK_EMAIL = 'yoju@embraced.co';
const GITHUB_DISCUSSIONS = 'https://github.com/embraced/yoju-site/discussions';
---

<footer class="mt-16 border-t border-yoju-border bg-yoju-bg-card">
  <div class="max-w-3xl mx-auto px-6 py-10 space-y-6">

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-5 text-base text-yoju-text-muted leading-relaxed">
      <p class="font-semibold text-yoju-text mb-1">⚠️ 免責聲明</p>
      <p>
        本站內容由 AI 輔助整理，並經多層來源查證（包含 SCImago Q1 學術期刊與官方衛生機構）。
        所有內容<strong>僅供衛教參考，不構成醫療建議</strong>。
        身體不適或需要診療，請諮詢您的醫師或醫療專業人員。
      </p>
    </div>

    <div class="text-base text-yoju-text-muted space-y-1">
      <p class="font-semibold text-yoju-text">📬 回饋與勘誤</p>
      <p>
        發現資訊有誤或需要補充？歡迎透過
        <a href={feedbackUrl} target="_blank" rel="noopener"
           class="text-yoju-orange underline">回饋表單</a>
        或寄信至
        <a href={`mailto:${FEEDBACK_EMAIL}?subject=yoju 文章回饋`}
           class="text-yoju-orange underline">{FEEDBACK_EMAIL}</a>
        告訴我們。
        醫療專業人士也歡迎在
        <a href={GITHUB_DISCUSSIONS}
           target="_blank" rel="noopener"
           class="text-yoju-orange underline">GitHub Discussions</a>
        交流設計理念。
      </p>
    </div>

    <p class="text-sm text-gray-400 text-center">
      © {new Date().getFullYear()} 有據 yoju · yoju.embraced.co
    </p>
  </div>
</footer>
