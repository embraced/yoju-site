---
interface Props {
  url: string;            // canonical article URL (used by FB OG crawler)
  tldr: string;
  greeting?: string;
  shortUrl?: string;      // optional /y/{id} alias for cleaner visible URL in shares
}
const { url, tldr, greeting, shortUrl } = Astro.props;

// Use short URL in the visible share text when available — it shows in the
// message body in LINE; the canonical long URL would wrap to 3-4 lines.
// The OG card preview still works because Cloudflare 301s short→canonical
// and OG crawlers follow redirects.
const displayUrl = shortUrl ?? url;
const shareMessage = `${greeting ?? tldr}\n\n${displayUrl}`;

// Universal Link `line.me/R/msg/text/?...` opens the LINE app directly on
// mobile (no Web-login redirect, unlike the social-plugins.line.me endpoint).
// On desktop / without LINE installed it falls back to LINE web.
const lineUrl = `https://line.me/R/msg/text/?${encodeURIComponent(shareMessage)}`;
const fbUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(displayUrl)}`;
---

<div class="flex flex-wrap gap-3 my-8">
  <a href={lineUrl} target="_blank" rel="noopener"
     class="inline-flex items-center gap-2 bg-[#06C755] hover:bg-[#05a847] text-white font-semibold
            px-5 py-3 rounded-lg text-base transition-colors">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.070 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
    </svg>
    分享到 LINE
  </a>

  <a href={fbUrl} target="_blank" rel="noopener"
     class="inline-flex items-center gap-2 bg-[#1877F2] hover:bg-[#166fe5] text-white font-semibold
            px-5 py-3 rounded-lg text-base transition-colors">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
    分享到 Facebook
  </a>
</div>
