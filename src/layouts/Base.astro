---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  articleUrl?: string;
}

const {
  title,
  description,
  ogImage = '/og/default.png',
  ogType = 'website',
  canonicalUrl = Astro.url.href,
  articleUrl,
} = Astro.props;

const siteName = '有據 yoju';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

// 站台層 JSON-LD（每頁都有）— 建立發布者實體，供文章 schema 引用、利於 AI 答案引擎辨識
const siteUrl = Astro.site?.href ?? 'https://yoju.embraced.co/';
const orgLogo = Astro.site ? new URL('/og/default.png', Astro.site).href : '/og/default.png';
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  inLanguage: 'zh-TW',
  description: '以實證醫學為基礎的繁體中文健康衛教，每篇文章附 PubMed／官方來源出處。',
  publisher: {
    '@type': 'Organization',
    name: siteName,
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: orgLogo },
  },
};
---

<!doctype html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>

  <!-- OG / LINE / Facebook -->
  <meta property="og:type"        content={ogType} />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={Astro.site ? new URL(ogImage, Astro.site).href : ogImage} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={Astro.site ? new URL(ogImage, Astro.site).href : ogImage} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- 站台結構化資料（AI 答案引擎 / GEO） -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />

  <!-- 頁面專屬 head（文章 Article JSON-LD 等） -->
  <slot name="head" />
</head>
<body>
  <header class="border-b border-yoju-border bg-yoju-bg-card">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
      <a href="/" class="text-2xl font-bold text-yoju-text hover:text-yoju-orange transition-colors shrink-0">
        有據 <span class="text-yoju-orange">yoju</span>
      </a>
      <nav class="flex items-center gap-4 sm:gap-6 text-base font-medium">
        <a href="/" class="text-yoju-text-muted hover:text-yoju-orange transition-colors">首頁</a>
        <a href="/articles" class="text-yoju-text-muted hover:text-yoju-orange transition-colors">全部文章</a>
        <a href="/about" class="text-yoju-text-muted hover:text-yoju-orange transition-colors">關於</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-10">
    <slot />
  </main>

  <Footer articleUrl={articleUrl} />
</body>
</html>
