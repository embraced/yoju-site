---
import { getCollection } from 'astro:content';
import Base from './Base.astro';
import TLDRBox from '../components/TLDRBox.astro';
import SourceList from '../components/SourceList.astro';
import ShareLine from '../components/ShareLine.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import { shortIdForSlug } from '../lib/short-url.mjs';

interface Source {
  title: string;
  url: string;
  journal?: string;
  quartile?: 'Q1' | 'Q2' | 'Q3' | 'Q4' | 'official';
  doi?: string;
  retracted: boolean;
}

interface SupersededBy {
  slug: string;
  date: string;
  title: string;
}

interface Props {
  title: string;
  date: string;
  category: string;
  tags: string[];
  tldr: string;
  greeting?: string;
  confidence: 'high' | 'medium';
  sources: Source[];
  slug: string;
  supersededBy?: SupersededBy;
  previousVersion?: SupersededBy;
  topicKey?: string;
  relatedTopicKeys?: string[];
}

const { title, date, category, tags, tldr, greeting, confidence, sources, slug, supersededBy, previousVersion } = Astro.props;
const articleUrl = Astro.site ? new URL(`/${slug}`, Astro.site).href : `/${slug}`;
const ogImage = `/og/${slug}.png`;

// Short share URL: /y/{YYMMDD}{a|b|...} — see scripts/gen-redirects.mjs.
// Computed from same algorithm so this article's render and the _redirects
// file agree (single source of truth in src/lib/short-url.mjs).
const allSlugs = (await getCollection('articles')).map((a) => a.id);
const shortId = shortIdForSlug(slug, allSlugs);
const articleShortUrl = Astro.site
  ? new URL(`/y/${shortId}`, Astro.site).href
  : `/y/${shortId}`;

const [y, m, d] = date.split('-').map(Number);
const formattedDate = new Date(y, m - 1, d).toLocaleDateString('zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const supersededFormattedDate = supersededBy
  ? (() => {
      const [yy, mm, dd] = supersededBy.date.split('-').map(Number);
      return new Date(yy, mm - 1, dd).toLocaleDateString('zh-TW', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
    })()
  : null;

const previousVersionFormattedDate = previousVersion
  ? (() => {
      const [yy, mm, dd] = previousVersion.date.split('-').map(Number);
      return new Date(yy, mm - 1, dd).toLocaleDateString('zh-TW', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
    })()
  : null;
---

<Base title={title} description={tldr} ogDescription={greeting ?? tldr} ogImage={ogImage} ogType="article" canonicalUrl={articleUrl} articleUrl={articleUrl}>
  <ArticleSchema slot="head" title={title} description={tldr} date={date} slug={slug} category={category} tags={tags} sources={sources} />
  <article>
    {supersededBy && (
      <aside class="mb-6 bg-yoju-orange/10 border-l-4 border-yoju-orange rounded-r-lg px-5 py-4 text-base text-yoju-text">
        <p class="font-semibold mb-1">📌 本文已有更新版</p>
        <p>
          本文於 <time datetime={supersededBy.date}>{supersededFormattedDate}</time> 推出更新版，
          建議閱讀：<a href={`/${supersededBy.slug}`}
                  class="text-yoju-orange underline font-semibold hover:text-yoju-orange-light">
            {supersededBy.title}
          </a>
        </p>
      </aside>
    )}

    {previousVersion && (
      <aside class="mb-6 bg-yoju-bg-card/60 border-l-2 border-yoju-border rounded-r px-5 py-3 text-sm text-yoju-text-muted">
        <p>
          📜 本文是更新版。前一版 (<time datetime={previousVersion.date}>{previousVersionFormattedDate}</time>)：
          <a href={`/${previousVersion.slug}`}
             class="text-yoju-orange underline hover:text-yoju-orange-light">
            {previousVersion.title}
          </a> — 內容已被本文整合，仍可作參考。
        </p>
      </aside>
    )}

    <header class="mb-6">
      <div class="flex items-center gap-2 mb-3">
        <a href={`/${category}`}
           class="text-sm font-semibold text-yoju-orange bg-amber-50 px-3 py-1 rounded-full hover:bg-amber-100 transition-colors">
          {category}
        </a>
        <time datetime={date} class="text-sm text-yoju-text-muted">{formattedDate}</time>
      </div>
      <h1 class="text-3xl font-bold leading-tight text-yoju-text">{title}</h1>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3">
          {tags.map((tag) => (
            <a href={`/tag/${tag}`}
               class="text-xs text-yoju-orange border border-yoju-orange/40 rounded-full px-2.5 py-0.5 hover:bg-yoju-orange/10 transition-colors">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <TLDRBox tldr={tldr} confidence={confidence} />

    <ShareLine url={articleUrl} title={title} tldr={tldr} shortUrl={articleShortUrl} />

    <div class="prose-article">
      <slot />
    </div>

    <ShareLine url={articleUrl} title={title} tldr={tldr} shortUrl={articleShortUrl} />

    <SourceList sources={sources} />

    <RelatedArticles currentSlug={slug} currentCategory={category} currentTags={tags} currentTopicKey={Astro.props.topicKey} currentRelatedTopicKeys={Astro.props.relatedTopicKeys} />
  </article>
</Base>
