---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter((a) => !a.data.superseded_by)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Base
  title="有據 yoju"
  description="給家人的每日衛教筆記。每天 1–3 篇健康資訊，來源查證，僅供參考。"
>
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-yoju-text mb-2">有據 yoju</h1>
    <p class="text-lg text-yoju-text-muted">給家人的每日衛教筆記 · 每篇均有來源查證</p>
  </div>

  {articles.length === 0 ? (
    <p class="text-lg text-yoju-text-muted">文章準備中，請稍後再來。</p>
  ) : (
    <div class="space-y-6">
      {articles.map((article) => (
        <ArticleCard
          slug={article.id}
          title={article.data.title}
          date={article.data.date}
          category={article.data.category}
          tldr={article.data.tldr}
          confidence={article.data.confidence}
        />
      ))}
    </div>
  )}
</Base>
