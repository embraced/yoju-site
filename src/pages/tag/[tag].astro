---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  const live = all.filter((a) => !a.data.superseded_by);

  // Build unique tag set
  const tagSet = new Set<string>();
  for (const a of live) {
    for (const t of a.data.tags) tagSet.add(t);
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      articles: live
        .filter((a) => a.data.tags.includes(tag))
        .sort((a, b) => b.data.date.localeCompare(a.data.date)),
    },
  }));
}

const { tag } = Astro.params;
const { articles } = Astro.props;
---

<Base
  title={`#${tag} — 有據 yoju`}
  description={`與「${tag}」相關的衛教文章，來源查證、僅供參考。`}
>
  <div class="mb-8">
    <a href="/" class="text-base text-yoju-orange hover:underline">← 回首頁</a>
    <div class="flex items-baseline gap-3 mt-3 flex-wrap">
      <span class="text-2xl text-yoju-text-muted">#</span>
      <h1 class="text-3xl font-bold text-yoju-text">{tag}</h1>
    </div>
    <p class="text-base text-yoju-text-muted mt-1">
      共 {articles.length} 篇含此標籤的文章
    </p>
  </div>

  <div class="space-y-6">
    {articles.map((article) => (
      <ArticleCard
        slug={article.id}
        title={article.data.title}
        date={article.data.date}
        category={article.data.category}
        tldr={article.data.tldr}
        confidence={article.data.confidence}
      />
    ))}
  </div>
</Base>
